# ==============================================================================
# SkillsSphere AI — Environment Variables
# ==============================================================================
# Copy this file to create your local .env files:
#   - Copy to server/.env (all server + interview-ai variables)
#   - Copy to client/.env (only VITE_* variables)
#
# NEVER commit real secrets to version control.
# For Railway deployment, set these as service environment variables.
# ==============================================================================

# ==============================================================================
# CLIENT CONFIGURATION (VITE_* prefix required for frontend access)
# ==============================================================================

# Backend API base URL used by the React frontend
# In production (Railway): set to your Railway server service URL, e.g. https://skillssphere-server-production.up.railway.app
# In development: defaults to http://localhost:5000
VITE_API_URL=http://localhost:5000

# Socket.IO server URL (optional — defaults to VITE_API_URL)
# Set this only if your WebSocket server is on a different URL than the API
# VITE_SOCKET_URL=http://localhost:5000

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# Server listen port (Railway sets this automatically)
PORT=5000

# Environment mode: development | production
NODE_ENV=development

# Trust reverse proxy headers (required for Railway, Heroku, etc.)
# Set to "true" when deployed behind a reverse proxy
TRUST_PROXY=false

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# MongoDB connection string
# Use mongodb+srv:// for Atlas, mongodb:// for local
# Set to "memory" for ephemeral in-memory database (development only)
MONGO_URI=mongodb://localhost:27017/skillssphere

# Redis connection URL (used for caching, rate limiting, token blacklist)
# Optional in development (server runs in degraded mode without it)
# Required for production rate limiting
REDIS_URL=redis://localhost:6379

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================

# JWT signing secret — REQUIRED
# Must be at least 32 characters in production. Must be unique.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# JWT token expiry duration (default: 7d)
JWT_EXPIRES_IN=7d

# HMAC-SHA256 secret for signing Google OAuth state tokens — REQUIRED
# Must be at least 32 characters. Must NOT be the same as JWT_SECRET.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=replace_with_a_32_character_random_hex_for_oauth_state_signing

# AES-256 key for field-level PII encryption — REQUIRED
# Must be at least 32 characters. Must NOT be the same as JWT_SECRET.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_a_32_character_random_hex_for_aes_256_gcm

# HMAC secret for signing protected file download URLs — REQUIRED
# Must be at least 32 characters. Must be unique from other secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FILE_URL_SIGNING_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ==============================================================================
# RATE LIMITING
# ==============================================================================

# Auth endpoint rate limiting
AUTH_LIMIT_WINDOW=900000
AUTH_LIMIT_MAX=5

# Resume upload rate limiting
RESUME_LIMIT_WINDOW=3600000
RESUME_LIMIT_MAX=10

# Socket.IO per-socket rate limiting
SOCKET_RATE_WINDOW_MS=10000
SOCKET_RATE_MAX_EVENTS=50
SOCKET_RATE_WHITELIST=ping,pong,connect,disconnect,error
SOCKET_RATE_ENABLED=true
SOCKET_RATE_WARNING_PERCENT=80
SOCKET_RATE_WARNING_COOLDOWN_MS=5000

# ==============================================================================
# FRONTEND URL (OAuth redirect + CORS)
# ==============================================================================

# URL of the React frontend — REQUIRED in production
# In production (Railway): set to your Railway client service URL
# In development: defaults to http://localhost:5174
FRONTEND_URL=http://localhost:5174

# Backend public URL (used for Swagger docs, resource URLs)
# Optional — defaults to http://localhost:PORT in development
# BACKEND_URL=https://your-server.up.railway.app

# ==============================================================================
# GOOGLE OAUTH
# ==============================================================================

# Google OAuth 2.0 credentials
# Get from: https://console.cloud.google.com/apis/credentials
# See docs/GOOGLE_OAUTH_SETUP.md for step-by-step guide
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ==============================================================================
# CLOUDINARY (Avatar Uploads — optional)
# ==============================================================================

# Server-side only — never expose API secret to the client
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================

# Email transport mode: "console" (dev) or "smtp" (production)
# In console mode, OTPs are printed to server logs
EMAIL_SERVICE_MODE=console

# SMTP settings (required if EMAIL_SERVICE_MODE=smtp)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="SkillsSphere AI <no-reply@skillssphere.ai>"

# ==============================================================================
# AI/ML CONFIGURATION
# ==============================================================================

# Hugging Face API token (free tier — required for semantic resume matching)
# Get at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hugging_face_token_here

# Google Gemini API key (required for AI Cover Letters, Roadmaps, AI Assistant)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# INTERVIEW AI SERVICE (Python microservice)
# ==============================================================================

# URL of the Python AI microservice for interview evaluation
# In production (Railway): set to your Railway interview-ai-service URL
# In development: defaults to http://localhost:8000
INTERVIEW_AI_URL=http://localhost:8000

# Trusted browser origins for the Python service CORS
INTERVIEW_AI_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173
INTERVIEW_AI_CORS_ALLOW_CREDENTIALS=true

# Maximum accepted audio payload size (bytes, default: 10MB)
INTERVIEW_AI_MAX_AUDIO_BYTES=10485760

# Timeout for evaluation requests (ms)
INTERVIEW_AI_TIMEOUT=10000

# Timeout for audio transcription requests (ms)
INTERVIEW_AI_TRANSCRIBE_TIMEOUT=30000

# Interview session data retention (days). Set to 0 to disable TTL.
INTERVIEW_RETENTION_DAYS=90

# Whisper model size (Python service): tiny|base|small|medium|large-v3
# Larger models are more accurate but require more memory
WHISPER_MODEL_SIZE=base

# ==============================================================================
# AI/ML EVALUATOR CONFIGURATION (optional — defaults applied if not set)
# ==============================================================================

EVALUATOR_SKILL_MATCH_ENABLED=true
EVALUATOR_KEYWORD_MATCH_ENABLED=true
EVALUATOR_EXPERIENCE_MATCH_ENABLED=true
EVALUATOR_SKILL_MATCH_WEIGHT=1.0
EVALUATOR_KEYWORD_MATCH_WEIGHT=0.2
EVALUATOR_EXPERIENCE_MATCH_WEIGHT=0.2
